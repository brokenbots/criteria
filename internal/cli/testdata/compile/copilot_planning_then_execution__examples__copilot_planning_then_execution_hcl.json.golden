{
  "name": "copilot_planning_then_execution",
  "initial_state": "plan",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 20,
    "MaxStepRetries": 0,
    "MaxVisitsWarnThreshold": 200
  },
  "adapters": [
    {
      "type": "copilot",
      "name": "engineer",
      "on_crash": "fail",
      "config_keys": [
        "max_turns",
        "model",
        "reasoning_effort"
      ]
    }
  ],
  "steps": [
    {
      "name": "plan",
      "adapter": "copilot.engineer",
      "input_keys": [
        "prompt",
        "reasoning_effort"
      ],
      "allow_tools": [
        "read_file"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "execute"
        }
      ]
    },
    {
      "name": "execute",
      "adapter": "copilot.engineer",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "read_file",
        "write_file",
        "shell:go build*",
        "shell:go test*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "done"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "done",
      "terminal": true,
      "success": true
    },
    {
      "name": "failed",
      "terminal": true,
      "success": false
    }
  ],
  "outputs": [],
  "step_order": [
    "plan",
    "execute"
  ],
  "plugins_required": [
    "copilot"
  ],
  "metadata": {
    "schema_version": 1
  }
}

{
  "name": "demo_tour_local",
  "initial_state": "boot",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 40,
    "MaxStepRetries": 0
  },
  "agents": [],
  "steps": [
    {
      "name": "boot",
      "adapter": "shell",
      "timeout": "10s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "aborted"
        },
        {
          "name": "success",
          "transition_to": "discover"
        }
      ]
    },
    {
      "name": "discover",
      "adapter": "shell",
      "timeout": "30s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "aborted"
        },
        {
          "name": "success",
          "transition_to": "process_each"
        }
      ]
    },
    {
      "name": "process_each",
      "adapter": "shell",
      "timeout": "30s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "all_succeeded",
          "transition_to": "review"
        },
        {
          "name": "any_failed",
          "transition_to": "aborted"
        }
      ]
    },
    {
      "name": "review",
      "adapter": "shell",
      "timeout": "10s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "aborted"
        },
        {
          "name": "success",
          "transition_to": "wait_brief"
        }
      ]
    },
    {
      "name": "celebrate",
      "adapter": "shell",
      "timeout": "10s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "aborted"
        },
        {
          "name": "success",
          "transition_to": "done"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "aborted",
      "terminal": true,
      "success": false
    },
    {
      "name": "done",
      "terminal": true,
      "success": true
    }
  ],
  "step_order": [
    "boot",
    "discover",
    "process_each",
    "review",
    "celebrate"
  ],
  "plugins_required": [
    "shell"
  ],
  "metadata": {
    "schema_version": 1
  }
}

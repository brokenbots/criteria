digraph "for_each_review_loop" {
  rankdir=LR;

  "init" [shape=box];
  "process_items" [shape=box];
  "done" [shape=doublecircle];
  "failed" [shape=doublecircle];

  "__start__" [shape=point,width=0.12,label=""];
  "__start__" -> "init" [label="initial"];
  "init" -> "process_items" [label="success"];
  "process_items" -> "done" [label="all_succeeded"];
  "process_items" -> "failed" [label="any_failed"];
}

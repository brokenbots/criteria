{
  "name": "for_each_review_loop",
  "initial_state": "init",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 50,
    "MaxStepRetries": 0,
    "MaxVisitsWarnThreshold": 200
  },
  "agents": [
    {
      "type": "noop",
      "name": "default",
      "on_crash": "fail",
      "config_keys": null
    }
  ],
  "steps": [
    {
      "name": "init",
      "adapter": "noop.default",
      "input_keys": [
        "result"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "success",
          "transition_to": "process_items"
        }
      ]
    },
    {
      "name": "process_items",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "all_succeeded",
          "transition_to": "done"
        },
        {
          "name": "any_failed",
          "transition_to": "failed"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "done",
      "terminal": true,
      "success": true
    },
    {
      "name": "failed",
      "terminal": true,
      "success": false
    }
  ],
  "outputs": [
    {
      "name": "status",
      "type": "string",
      "description": "Final status of the iteration processing"
    },
    {
      "name": "processed_items",
      "description": "List of items that were processed"
    }
  ],
  "step_order": [
    "init",
    "process_items"
  ],
  "plugins_required": [
    "noop"
  ],
  "metadata": {
    "schema_version": 1
  }
}

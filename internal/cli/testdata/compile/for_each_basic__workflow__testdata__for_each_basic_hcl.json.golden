{
  "name": "for_each_basic",
  "initial_state": "deploy_all",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 100,
    "MaxStepRetries": 0
  },
  "agents": [],
  "steps": [
    {
      "name": "deploy_one",
      "adapter": "noop",
      "input_keys": [
        "value"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "_continue"
        },
        {
          "name": "success",
          "transition_to": "_continue"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "done",
      "terminal": true,
      "success": true
    },
    {
      "name": "failed",
      "terminal": true,
      "success": false
    }
  ],
  "step_order": [
    "deploy_one"
  ],
  "plugins_required": [
    "noop"
  ],
  "metadata": {
    "schema_version": 1
  }
}

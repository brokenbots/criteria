{
  "name": "workstream_review_loop",
  "initial_state": "checkout_branch",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 120,
    "MaxStepRetries": 0,
    "MaxVisitsWarnThreshold": 200
  },
  "adapters": [
    {
      "type": "copilot",
      "name": "executor",
      "on_crash": "fail",
      "config_keys": [
        "max_turns",
        "model",
        "reasoning_effort",
        "system_prompt"
      ]
    },
    {
      "type": "copilot",
      "name": "pr_manager",
      "on_crash": "fail",
      "config_keys": [
        "max_turns",
        "model",
        "system_prompt"
      ]
    },
    {
      "type": "copilot",
      "name": "reviewer",
      "on_crash": "fail",
      "config_keys": [
        "max_turns",
        "model",
        "reasoning_effort",
        "system_prompt"
      ]
    },
    {
      "type": "shell",
      "name": "default",
      "on_crash": "fail",
      "config_keys": null
    }
  ],
  "steps": [
    {
      "name": "checkout_branch",
      "adapter": "shell.default",
      "timeout": "10s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "execute_init"
        }
      ]
    },
    {
      "name": "execute_init",
      "adapter": "copilot.executor",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "needs_approval",
          "transition_to": "review_init"
        },
        {
          "name": "needs_review",
          "transition_to": "review_init"
        }
      ]
    },
    {
      "name": "review_init",
      "adapter": "copilot.reviewer",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "approved",
          "transition_to": "commit_and_prepare_pr"
        },
        {
          "name": "changes_requested",
          "transition_to": "execute"
        },
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "needs_approval",
          "transition_to": "execute"
        },
        {
          "name": "needs_review",
          "transition_to": "execute"
        }
      ]
    },
    {
      "name": "execute",
      "adapter": "copilot.executor",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "needs_approval",
          "transition_to": "verify"
        },
        {
          "name": "needs_review",
          "transition_to": "verify"
        },
        {
          "name": "success",
          "transition_to": "verify"
        }
      ]
    },
    {
      "name": "verify",
      "adapter": "shell.default",
      "timeout": "2m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "fix_verify"
        },
        {
          "name": "success",
          "transition_to": "review"
        }
      ]
    },
    {
      "name": "fix_verify",
      "adapter": "copilot.executor",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "needs_approval",
          "transition_to": "verify"
        },
        {
          "name": "needs_review",
          "transition_to": "verify"
        }
      ]
    },
    {
      "name": "review",
      "adapter": "copilot.reviewer",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "approved",
          "transition_to": "commit_and_prepare_pr"
        },
        {
          "name": "changes_requested",
          "transition_to": "execute"
        },
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "needs_approval",
          "transition_to": "execute"
        },
        {
          "name": "needs_review",
          "transition_to": "execute"
        }
      ]
    },
    {
      "name": "commit_and_prepare_pr",
      "adapter": "copilot.executor",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "open_or_update_pr"
        }
      ]
    },
    {
      "name": "open_or_update_pr",
      "adapter": "copilot.pr_manager",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "needs_approval",
          "transition_to": "watch_pr_warmup"
        },
        {
          "name": "needs_review",
          "transition_to": "watch_pr_warmup"
        },
        {
          "name": "watch_pr",
          "transition_to": "watch_pr_warmup"
        }
      ]
    },
    {
      "name": "watch_pr_warmup",
      "adapter": "shell.default",
      "timeout": "3m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "triage_pr_feedback"
        },
        {
          "name": "success",
          "transition_to": "watch_pr_gate"
        }
      ]
    },
    {
      "name": "watch_pr_backoff",
      "adapter": "shell.default",
      "timeout": "5m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "triage_pr_feedback"
        },
        {
          "name": "success",
          "transition_to": "watch_pr_gate"
        }
      ]
    },
    {
      "name": "watch_pr_gate",
      "adapter": "shell.default",
      "timeout": "45m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "triage_pr_feedback"
        },
        {
          "name": "success",
          "transition_to": "merge_pr_and_sync_main"
        }
      ]
    },
    {
      "name": "triage_pr_feedback",
      "adapter": "copilot.pr_manager",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "merged",
          "transition_to": "merge_pr_and_sync_main"
        },
        {
          "name": "needs_approval",
          "transition_to": "watch_pr_backoff"
        },
        {
          "name": "needs_executor",
          "transition_to": "execute_pr_feedback"
        },
        {
          "name": "needs_review",
          "transition_to": "watch_pr_backoff"
        },
        {
          "name": "recheck",
          "transition_to": "watch_pr_backoff"
        },
        {
          "name": "watch_pr",
          "transition_to": "watch_pr_backoff"
        }
      ]
    },
    {
      "name": "execute_pr_feedback",
      "adapter": "copilot.executor",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "needs_approval",
          "transition_to": "verify"
        },
        {
          "name": "needs_review",
          "transition_to": "verify"
        },
        {
          "name": "success",
          "transition_to": "verify"
        }
      ]
    },
    {
      "name": "merge_pr_and_sync_main",
      "adapter": "shell.default",
      "timeout": "5m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "done"
        },
        {
          "name": "success",
          "transition_to": "done"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "done",
      "terminal": true,
      "success": true
    },
    {
      "name": "failed",
      "terminal": true,
      "success": false
    }
  ],
  "outputs": [],
  "step_order": [
    "checkout_branch",
    "execute_init",
    "review_init",
    "execute",
    "verify",
    "fix_verify",
    "review",
    "commit_and_prepare_pr",
    "open_or_update_pr",
    "watch_pr_warmup",
    "watch_pr_backoff",
    "watch_pr_gate",
    "triage_pr_feedback",
    "execute_pr_feedback",
    "merge_pr_and_sync_main"
  ],
  "plugins_required": [
    "copilot",
    "shell"
  ],
  "metadata": {
    "schema_version": 1
  }
}

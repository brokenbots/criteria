{
  "name": "build_and_test",
  "initial_state": "build",
  "target_state": "verified",
  "policy": {
    "MaxTotalSteps": 20,
    "MaxStepRetries": 0,
    "MaxVisitsWarnThreshold": 200
  },
  "adapters": [
    {
      "type": "shell",
      "name": "default",
      "on_crash": "fail",
      "config_keys": null
    }
  ],
  "steps": [
    {
      "name": "build",
      "adapter": "shell.default",
      "timeout": "5m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "next": "failed"
        },
        {
          "name": "success",
          "next": "test"
        }
      ]
    },
    {
      "name": "test",
      "adapter": "shell.default",
      "timeout": "10m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "next": "failed"
        },
        {
          "name": "success",
          "next": "verified"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "failed",
      "terminal": true,
      "success": false
    },
    {
      "name": "verified",
      "terminal": true,
      "success": true
    }
  ],
  "outputs": [],
  "switches": [],
  "step_order": [
    "build",
    "test"
  ],
  "plugins_required": [
    "shell"
  ],
  "metadata": {
    "schema_version": 1
  }
}

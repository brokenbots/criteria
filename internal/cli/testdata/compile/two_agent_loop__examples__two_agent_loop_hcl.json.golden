{
  "name": "two_agent_loop",
  "initial_state": "open_executor",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 50,
    "MaxStepRetries": 0
  },
  "agents": [
    {
      "name": "executor",
      "adapter": "copilot",
      "on_crash": "fail",
      "config_keys": [
        "max_turns",
        "system_prompt"
      ]
    },
    {
      "name": "reviewer",
      "adapter": "copilot",
      "on_crash": "fail",
      "config_keys": [
        "max_turns",
        "system_prompt"
      ]
    }
  ],
  "steps": [
    {
      "name": "open_executor",
      "agent": "executor",
      "lifecycle": "open",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "open_reviewer"
        }
      ]
    },
    {
      "name": "open_reviewer",
      "agent": "reviewer",
      "lifecycle": "open",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_executor_failed"
        },
        {
          "name": "success",
          "transition_to": "execute"
        }
      ]
    },
    {
      "name": "execute",
      "agent": "executor",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "read_file",
        "write_file",
        "shell:git diff",
        "shell:go build*",
        "shell:go test*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_reviewer_failed"
        },
        {
          "name": "needs_review",
          "transition_to": "review"
        },
        {
          "name": "success",
          "transition_to": "review"
        }
      ]
    },
    {
      "name": "review",
      "agent": "reviewer",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "read_file",
        "shell:git diff"
      ],
      "outcomes": [
        {
          "name": "approved",
          "transition_to": "close_reviewer_done"
        },
        {
          "name": "changes_requested",
          "transition_to": "execute"
        },
        {
          "name": "failure",
          "transition_to": "close_reviewer_failed"
        },
        {
          "name": "needs_review",
          "transition_to": "execute"
        }
      ]
    },
    {
      "name": "close_reviewer_done",
      "agent": "reviewer",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_executor_failed"
        },
        {
          "name": "success",
          "transition_to": "close_executor_done"
        }
      ]
    },
    {
      "name": "close_reviewer_failed",
      "agent": "reviewer",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_executor_failed"
        },
        {
          "name": "success",
          "transition_to": "close_executor_failed"
        }
      ]
    },
    {
      "name": "close_executor_done",
      "agent": "executor",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "done"
        }
      ]
    },
    {
      "name": "close_executor_failed",
      "agent": "executor",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "failed"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "done",
      "terminal": true,
      "success": true
    },
    {
      "name": "failed",
      "terminal": true,
      "success": false
    }
  ],
  "step_order": [
    "open_executor",
    "open_reviewer",
    "execute",
    "review",
    "close_reviewer_done",
    "close_reviewer_failed",
    "close_executor_done",
    "close_executor_failed"
  ],
  "plugins_required": [
    "copilot"
  ],
  "metadata": {
    "schema_version": 1
  }
}

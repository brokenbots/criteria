digraph "workstream_review_loop" {
  rankdir=LR;

  "load_executor_agent_file" [shape=box];
  "load_reviewer_agent_file" [shape=box];
  "load_pr_manager_agent_file" [shape=box];
  "checkout_branch" [shape=box];
  "open_executor" [shape=box];
  "open_reviewer" [shape=box];
  "open_pr_manager" [shape=box];
  "execute_init" [shape=box];
  "review_init" [shape=box];
  "execute" [shape=box];
  "verify" [shape=box];
  "fix_verify" [shape=box];
  "review" [shape=box];
  "commit_and_prepare_pr" [shape=box];
  "open_or_update_pr" [shape=box];
  "watch_pr_warmup" [shape=box];
  "watch_pr_backoff" [shape=box];
  "watch_pr_gate" [shape=box];
  "triage_pr_feedback" [shape=box];
  "execute_pr_feedback" [shape=box];
  "merge_pr_and_sync_main" [shape=box];
  "close_pr_manager_done" [shape=box];
  "close_reviewer_done" [shape=box];
  "close_executor_done" [shape=box];
  "close_pr_manager_abort" [shape=box];
  "close_reviewer_abort" [shape=box];
  "close_executor_abort" [shape=box];
  "done" [shape=doublecircle];
  "failed" [shape=doublecircle];

  "__start__" [shape=point,width=0.12,label=""];
  "__start__" -> "load_executor_agent_file" [label="initial"];
  "load_executor_agent_file" -> "failed" [label="failure"];
  "load_executor_agent_file" -> "load_reviewer_agent_file" [label="success"];
  "load_reviewer_agent_file" -> "failed" [label="failure"];
  "load_reviewer_agent_file" -> "load_pr_manager_agent_file" [label="success"];
  "load_pr_manager_agent_file" -> "failed" [label="failure"];
  "load_pr_manager_agent_file" -> "checkout_branch" [label="success"];
  "checkout_branch" -> "failed" [label="failure"];
  "checkout_branch" -> "open_executor" [label="success"];
  "open_executor" -> "failed" [label="failure"];
  "open_executor" -> "open_reviewer" [label="success"];
  "open_reviewer" -> "close_executor_abort" [label="failure"];
  "open_reviewer" -> "open_pr_manager" [label="success"];
  "open_pr_manager" -> "close_reviewer_abort" [label="failure"];
  "open_pr_manager" -> "execute_init" [label="success"];
  "execute_init" -> "close_pr_manager_abort" [label="failure"];
  "execute_init" -> "review_init" [label="needs_approval"];
  "execute_init" -> "review_init" [label="needs_review"];
  "review_init" -> "commit_and_prepare_pr" [label="approved"];
  "review_init" -> "execute" [label="changes_requested"];
  "review_init" -> "close_pr_manager_abort" [label="failure"];
  "review_init" -> "execute" [label="needs_approval"];
  "review_init" -> "execute" [label="needs_review"];
  "execute" -> "close_pr_manager_abort" [label="failure"];
  "execute" -> "verify" [label="needs_approval"];
  "execute" -> "verify" [label="needs_review"];
  "verify" -> "fix_verify" [label="failure"];
  "verify" -> "review" [label="success"];
  "fix_verify" -> "close_pr_manager_abort" [label="failure"];
  "fix_verify" -> "verify" [label="needs_approval"];
  "fix_verify" -> "verify" [label="needs_review"];
  "review" -> "commit_and_prepare_pr" [label="approved"];
  "review" -> "execute" [label="changes_requested"];
  "review" -> "close_pr_manager_abort" [label="failure"];
  "review" -> "execute" [label="needs_approval"];
  "review" -> "execute" [label="needs_review"];
  "commit_and_prepare_pr" -> "close_pr_manager_abort" [label="failure"];
  "commit_and_prepare_pr" -> "open_or_update_pr" [label="success"];
  "open_or_update_pr" -> "close_pr_manager_abort" [label="failure"];
  "open_or_update_pr" -> "watch_pr_warmup" [label="needs_approval"];
  "open_or_update_pr" -> "watch_pr_warmup" [label="needs_review"];
  "open_or_update_pr" -> "watch_pr_warmup" [label="watch_pr"];
  "watch_pr_warmup" -> "triage_pr_feedback" [label="failure"];
  "watch_pr_warmup" -> "watch_pr_gate" [label="success"];
  "watch_pr_backoff" -> "triage_pr_feedback" [label="failure"];
  "watch_pr_backoff" -> "watch_pr_gate" [label="success"];
  "watch_pr_gate" -> "triage_pr_feedback" [label="failure"];
  "watch_pr_gate" -> "merge_pr_and_sync_main" [label="success"];
  "triage_pr_feedback" -> "close_pr_manager_abort" [label="failure"];
  "triage_pr_feedback" -> "watch_pr_backoff" [label="needs_approval"];
  "triage_pr_feedback" -> "execute_pr_feedback" [label="needs_executor"];
  "triage_pr_feedback" -> "watch_pr_backoff" [label="needs_review"];
  "triage_pr_feedback" -> "watch_pr_backoff" [label="recheck"];
  "triage_pr_feedback" -> "watch_pr_backoff" [label="watch_pr"];
  "execute_pr_feedback" -> "close_pr_manager_abort" [label="failure"];
  "execute_pr_feedback" -> "verify" [label="needs_approval"];
  "execute_pr_feedback" -> "verify" [label="needs_review"];
  "merge_pr_and_sync_main" -> "triage_pr_feedback" [label="failure"];
  "merge_pr_and_sync_main" -> "close_pr_manager_done" [label="success"];
  "close_pr_manager_done" -> "close_reviewer_done" [label="failure"];
  "close_pr_manager_done" -> "close_reviewer_done" [label="success"];
  "close_reviewer_done" -> "close_executor_done" [label="failure"];
  "close_reviewer_done" -> "close_executor_done" [label="success"];
  "close_executor_done" -> "done" [label="failure"];
  "close_executor_done" -> "done" [label="success"];
  "close_pr_manager_abort" -> "close_reviewer_abort" [label="failure"];
  "close_pr_manager_abort" -> "close_reviewer_abort" [label="success"];
  "close_reviewer_abort" -> "close_executor_abort" [label="failure"];
  "close_reviewer_abort" -> "close_executor_abort" [label="success"];
  "close_executor_abort" -> "failed" [label="failure"];
  "close_executor_abort" -> "failed" [label="success"];
}

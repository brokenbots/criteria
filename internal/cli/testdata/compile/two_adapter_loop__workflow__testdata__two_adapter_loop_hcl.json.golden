{
  "name": "two_agent_loop",
  "initial_state": "execute",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 100,
    "MaxStepRetries": 0,
    "MaxVisitsWarnThreshold": 200
  },
  "adapters": [
    {
      "type": "copilot",
      "name": "executor",
      "on_crash": "respawn",
      "config_keys": null
    },
    {
      "type": "copilot",
      "name": "reviewer",
      "on_crash": "fail",
      "config_keys": null
    }
  ],
  "steps": [
    {
      "name": "execute",
      "adapter": "copilot.executor",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "approved",
          "next": "review"
        },
        {
          "name": "retry",
          "next": "review"
        }
      ]
    },
    {
      "name": "review",
      "adapter": "copilot.reviewer",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "approved",
          "next": "done"
        },
        {
          "name": "changes",
          "next": "execute"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "done",
      "terminal": true,
      "success": true
    }
  ],
  "outputs": [],
  "step_order": [
    "execute",
    "review"
  ],
  "plugins_required": [
    "copilot"
  ],
  "metadata": {
    "schema_version": 1
  }
}

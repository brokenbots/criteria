digraph "phase3_subworkflow_demo" {
  rankdir=LR;

  "setup" [shape=box, style="filled", fillcolor="#D6EAF8"];
  "done" [shape=doublecircle, style=filled, fillcolor="#D5F5E3"];

  "__start__" [shape=point,width=0.12,label=""];
  "__start__" -> "setup" [label="initial"];
  "setup" -> "done" [label="failure"];
  "setup" -> "done" [label="success"];
}

digraph "copilot_planning_then_execution" {
  rankdir=LR;

  "plan" [shape=box];
  "execute" [shape=box];
  "done" [shape=doublecircle];
  "failed" [shape=doublecircle];

  "__start__" [shape=point,width=0.12,label=""];
  "__start__" -> "plan" [label="initial"];
  "plan" -> "failed" [label="failure"];
  "plan" -> "execute" [label="success"];
  "execute" -> "failed" [label="failure"];
  "execute" -> "done" [label="success"];
}

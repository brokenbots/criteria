{
  "name": "switch_basic",
  "initial_state": "build",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 100,
    "MaxStepRetries": 0,
    "MaxVisitsWarnThreshold": 200
  },
  "adapters": [
    {
      "type": "noop",
      "name": "default",
      "on_crash": "fail",
      "config_keys": null
    }
  ],
  "steps": [
    {
      "name": "build",
      "adapter": "noop.default",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "success",
          "next": "decide"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "deploy",
      "terminal": true,
      "success": true
    },
    {
      "name": "deploy_staging",
      "terminal": true,
      "success": true
    },
    {
      "name": "done",
      "terminal": true,
      "success": true
    },
    {
      "name": "skip_deploy",
      "terminal": true,
      "success": true
    }
  ],
  "outputs": [],
  "switches": [
    {
      "name": "decide",
      "conditions": [
        {
          "match": "var.env == \"prod\"",
          "next": "deploy"
        },
        {
          "match": "var.env == \"staging\"",
          "next": "deploy_staging"
        },
        {
          "match": "steps.build.exit_code == \"0\"",
          "next": "deploy_staging"
        }
      ],
      "default_next": "skip_deploy"
    }
  ],
  "step_order": [
    "build"
  ],
  "plugins_required": [
    "noop"
  ],
  "metadata": {
    "schema_version": 1
  }
}

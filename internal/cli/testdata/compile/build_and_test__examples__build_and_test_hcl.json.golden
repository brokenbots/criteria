{
  "name": "build_and_test",
  "initial_state": "build",
  "target_state": "verified",
  "policy": {
    "MaxTotalSteps": 20,
    "MaxStepRetries": 0,
    "MaxVisitsWarnThreshold": 200
  },
  "agents": [],
  "steps": [
    {
      "name": "build",
      "adapter": "shell",
      "timeout": "5m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "test"
        }
      ]
    },
    {
      "name": "test",
      "adapter": "shell",
      "timeout": "10m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "verified"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "failed",
      "terminal": true,
      "success": false
    },
    {
      "name": "verified",
      "terminal": true,
      "success": true
    }
  ],
  "step_order": [
    "build",
    "test"
  ],
  "plugins_required": [
    "shell"
  ],
  "metadata": {
    "schema_version": 1
  }
}

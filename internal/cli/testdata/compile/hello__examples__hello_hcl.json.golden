{
  "name": "hello",
  "initial_state": "say_hello",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 100,
    "MaxStepRetries": 0,
    "MaxVisitsWarnThreshold": 200
  },
  "adapters": [
    {
      "type": "shell",
      "name": "default",
      "on_crash": "fail",
      "config_keys": null
    }
  ],
  "steps": [
    {
      "name": "say_hello",
      "adapter": "shell.default",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "next": "failed"
        },
        {
          "name": "success",
          "next": "done"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "done",
      "terminal": true,
      "success": true
    },
    {
      "name": "failed",
      "terminal": true,
      "success": false
    }
  ],
  "outputs": [
    {
      "name": "greeting",
      "type": "string",
      "description": "The greeting message produced by the workflow"
    }
  ],
  "step_order": [
    "say_hello"
  ],
  "plugins_required": [
    "shell"
  ],
  "metadata": {
    "schema_version": 1
  }
}

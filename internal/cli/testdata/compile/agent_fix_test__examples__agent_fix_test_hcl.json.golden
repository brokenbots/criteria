{
  "name": "agent_fix_test",
  "initial_state": "test",
  "target_state": "verified",
  "policy": {
    "MaxTotalSteps": 30,
    "MaxStepRetries": 2
  },
  "agents": [],
  "steps": [
    {
      "name": "test",
      "adapter": "shell",
      "timeout": "5m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "fix"
        },
        {
          "name": "success",
          "transition_to": "verified"
        }
      ]
    },
    {
      "name": "fix",
      "adapter": "copilot",
      "timeout": "30m0s",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "needs_review",
          "transition_to": "awaiting_human"
        },
        {
          "name": "success",
          "transition_to": "test"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "awaiting_human",
      "terminal": true,
      "success": false
    },
    {
      "name": "failed",
      "terminal": true,
      "success": false
    },
    {
      "name": "verified",
      "terminal": true,
      "success": true
    }
  ],
  "step_order": [
    "test",
    "fix"
  ],
  "plugins_required": [
    "copilot",
    "shell"
  ],
  "metadata": {
    "schema_version": 1
  }
}

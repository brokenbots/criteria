workflow: demo_tour  (version 1)
initial_state: boot   target_state: done
policy: max_total_steps=40  max_step_retries=0

variables:
  mode: string = v1.5
  phase_count: number = 3

agents:
  (none)

steps (declaration order):
  boot   adapter=shell   timeout=10s
    input keys: command
    allow_tools: (none)
    outcomes: success -> discover, failure -> aborted
  discover   adapter=shell   timeout=30s
    input keys: command
    allow_tools: (none)
    outcomes: success -> process_each, failure -> aborted
  process   adapter=shell   timeout=30s
    input keys: command
    allow_tools: (none)
    outcomes: success -> _continue, failure -> _continue
  review   adapter=shell   timeout=10s
    input keys: command
    allow_tools: (none)
    outcomes: success -> wait_for_window, failure -> aborted
  celebrate   adapter=shell   timeout=10s
    input keys: command
    allow_tools: (none)
    outcomes: success -> done, failure -> aborted

states:
  aborted    terminal=true   success=false
  done    terminal=true   success=true

plugins required:
  shell   (search: $OVERLORD_PLUGINS, ~/.overlord/plugins)

workflow: workstream_review_loop  (version 1)
initial_state: load_executor_agent_file   target_state: done
policy: max_total_steps=50  max_step_retries=0

variables:
  workstream_file: string = workstreams/02-castle-mode-integration.md

agents:
  executor   adapter=copilot   on_crash=fail
    config: max_turns=12, model=claude-sonnet-4.6, reasoning_effort=medium
  reviewer   adapter=copilot   on_crash=fail
    config: max_turns=10, model=claude-sonnet-4.6, reasoning_effort=high

steps (declaration order):
  load_executor_agent_file   adapter=shell   timeout=10s
    input keys: command
    allow_tools: (none)
    outcomes: success -> load_reviewer_agent_file, failure -> failed
  load_reviewer_agent_file   adapter=shell   timeout=10s
    input keys: command
    allow_tools: (none)
    outcomes: success -> checkout_branch, failure -> failed
  checkout_branch   adapter=shell   timeout=10s
    input keys: command
    allow_tools: (none)
    outcomes: success -> open_executor, failure -> failed
  open_executor   agent=executor   lifecycle=open
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> open_reviewer, failure -> failed
  open_reviewer   agent=reviewer   lifecycle=open
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> execute_init, failure -> close_executor_abort
  execute_init   agent=executor
    input keys: prompt
    allow_tools: *
    outcomes: needs_review -> review_init, needs_approval -> review_init, failure -> close_reviewer_abort
  review_init   agent=reviewer
    input keys: prompt
    allow_tools: *
    outcomes: approved -> commit_and_finish, changes_requested -> execute, needs_review -> execute, needs_approval -> execute, failure -> close_reviewer_abort
  execute   agent=executor
    input keys: prompt
    allow_tools: *
    outcomes: needs_review -> verify, needs_approval -> verify, failure -> close_reviewer_abort
  verify   adapter=shell   timeout=2m0s
    input keys: command
    allow_tools: (none)
    outcomes: success -> review, failure -> fix_verify
  fix_verify   agent=executor
    input keys: prompt
    allow_tools: *
    outcomes: needs_review -> verify, needs_approval -> verify, failure -> close_reviewer_abort
  review   agent=reviewer
    input keys: prompt
    allow_tools: *
    outcomes: approved -> commit_and_finish, changes_requested -> execute, needs_review -> execute, needs_approval -> execute, failure -> close_reviewer_abort
  commit_and_finish   agent=executor
    input keys: prompt
    allow_tools: *
    outcomes: success -> close_reviewer_done, failure -> close_reviewer_abort
  close_reviewer_done   agent=reviewer   lifecycle=close
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> close_executor_done, failure -> close_executor_done
  close_executor_done   agent=executor   lifecycle=close
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> done, failure -> done
  close_reviewer_abort   agent=reviewer   lifecycle=close
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> close_executor_abort, failure -> close_executor_abort
  close_executor_abort   agent=executor   lifecycle=close
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> failed, failure -> failed

states:
  done    terminal=true   success=true
  failed    terminal=true   success=false

plugins required:
  copilot   (search: $OVERSEER_PLUGINS, ~/.overseer/plugins)
  shell   (search: $OVERSEER_PLUGINS, ~/.overseer/plugins)

workflow: two_agent_loop  (version 0.1)
initial_state: open_executor   target_state: done
policy: max_total_steps=100  max_step_retries=0

variables:
  (none)

adapters:
  copilot.executor   type=copilot   on_crash=respawn
    config: (none)
  copilot.reviewer   type=copilot   on_crash=fail
    config: (none)

steps (declaration order):
  open_executor   adapter=copilot.executor   lifecycle=open
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> open_reviewer
  open_reviewer   adapter=copilot.reviewer   lifecycle=open
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> execute
  execute   adapter=copilot.executor
    input keys: (none)
    allow_tools: (none)
    outcomes: approved -> close_reviewer, retry -> review
  review   adapter=copilot.reviewer
    input keys: (none)
    allow_tools: (none)
    outcomes: approved -> close_reviewer, changes -> execute
  close_reviewer   adapter=copilot.reviewer   lifecycle=close
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> close_executor
  close_executor   adapter=copilot.executor   lifecycle=close
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> done

states:
  done    terminal=true   success=true

plugins required:
  copilot   (search: $CRITERIA_PLUGINS, ~/.criteria/plugins)

workflow: for_each_basic  (version 0.1)
initial_state: deploy_all   target_state: done
policy: max_total_steps=100  max_step_retries=0

variables:
  (none)

agents:
  (none)

steps (declaration order):
  deploy_one   adapter=noop
    input keys: value
    allow_tools: (none)
    outcomes: success -> _continue, failure -> _continue

states:
  done    terminal=true   success=true
  failed    terminal=true   success=false

plugins required:
  noop   (search: $OVERLORD_PLUGINS, ~/.overlord/plugins)

workflow: build_and_test  (version 0.1)
initial_state: build   target_state: verified
policy: max_total_steps=20  max_step_retries=0

variables:
  (none)

adapters:
  shell.default   type=shell   on_crash=fail
    config: (none)

steps (declaration order):
  build   adapter=shell.default   timeout=5m0s
    input keys: command
    allow_tools: (none)
    outcomes: success -> test, failure -> failed
  test   adapter=shell.default   timeout=10m0s
    input keys: command
    allow_tools: (none)
    outcomes: success -> verified, failure -> failed

states:
  failed    terminal=true   success=false
  verified    terminal=true   success=true

plugins required:
  shell   (search: $CRITERIA_PLUGINS, ~/.criteria/plugins)

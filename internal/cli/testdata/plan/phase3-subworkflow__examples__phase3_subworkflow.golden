workflow: phase3_subworkflow_demo  (version 0.1)
initial_state: setup   target_state: done
policy: max_total_steps=100  max_step_retries=0

variables:
  (none)

adapters:
  shell.default   type=shell   on_crash=fail
    config: (none)

steps (declaration order):
  setup   adapter=shell.default
    input keys: command
    allow_tools: (none)
    outcomes: success -> done, failure -> done

states:
  done    terminal=true   success=true

plugins required:
  shell   (search: $CRITERIA_PLUGINS, ~/.criteria/plugins)

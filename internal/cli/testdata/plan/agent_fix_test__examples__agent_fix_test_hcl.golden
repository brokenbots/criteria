workflow: agent_fix_test  (version 0.1)
initial_state: test   target_state: verified
policy: max_total_steps=30  max_step_retries=2

variables:
  (none)

agents:
  (none)

steps (declaration order):
  test   adapter=shell   timeout=5m0s
    input keys: command
    allow_tools: (none)
    outcomes: success -> verified, failure -> fix
  fix   adapter=copilot   timeout=30m0s
    input keys: prompt
    allow_tools: (none)
    outcomes: success -> test, needs_review -> awaiting_human, failure -> failed

states:
  awaiting_human    terminal=true   success=false   requires=human_input
  failed    terminal=true   success=false
  verified    terminal=true   success=true

plugins required:
  copilot   (search: $CRITERIA_PLUGINS, ~/.criteria/plugins)
  shell   (search: $CRITERIA_PLUGINS, ~/.criteria/plugins)

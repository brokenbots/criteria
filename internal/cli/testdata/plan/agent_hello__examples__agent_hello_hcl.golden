workflow: agent_hello  (version 1)
initial_state: open_assistant   target_state: done
policy: max_total_steps=100  max_step_retries=0

variables:
  (none)

agents:
  assistant   adapter=copilot   on_crash=fail
    config: max_turns=4

steps (declaration order):
  open_assistant   agent=assistant   lifecycle=open
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> ask, failure -> failed
  ask   agent=assistant
    input keys: prompt
    allow_tools: shell:git*status*
    outcomes: success -> close_done, needs_review -> close_needs_review, failure -> close_failed
  close_done   agent=assistant   lifecycle=close
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> done, failure -> failed
  close_needs_review   agent=assistant   lifecycle=close
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> needs_review, failure -> failed
  close_failed   agent=assistant   lifecycle=close
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> failed, failure -> failed

states:
  done    terminal=true   success=true
  failed    terminal=true   success=false
  needs_review    terminal=true   success=false   requires=human_input

plugins required:
  copilot   (search: $OVERSEER_PLUGINS, ~/.overseer/plugins)

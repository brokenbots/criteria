{
  "name": "workstream_review_loop",
  "initial_state": "load_executor_agent_file",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 50,
    "MaxStepRetries": 0
  },
  "agents": [
    {
      "name": "executor",
      "adapter": "copilot",
      "on_crash": "fail",
      "config_keys": [
        "max_turns",
        "model",
        "reasoning_effort"
      ]
    },
    {
      "name": "reviewer",
      "adapter": "copilot",
      "on_crash": "fail",
      "config_keys": [
        "max_turns",
        "model",
        "reasoning_effort"
      ]
    }
  ],
  "steps": [
    {
      "name": "load_executor_agent_file",
      "adapter": "shell",
      "timeout": "10s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "load_reviewer_agent_file"
        }
      ]
    },
    {
      "name": "load_reviewer_agent_file",
      "adapter": "shell",
      "timeout": "10s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "open_executor"
        }
      ]
    },
    {
      "name": "open_executor",
      "agent": "executor",
      "lifecycle": "open",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "open_reviewer"
        }
      ]
    },
    {
      "name": "open_reviewer",
      "agent": "reviewer",
      "lifecycle": "open",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_executor_abort"
        },
        {
          "name": "success",
          "transition_to": "execute_init"
        }
      ]
    },
    {
      "name": "execute_init",
      "agent": "executor",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_reviewer_abort"
        },
        {
          "name": "needs_approval",
          "transition_to": "review_init"
        },
        {
          "name": "needs_review",
          "transition_to": "review_init"
        }
      ]
    },
    {
      "name": "review_init",
      "agent": "reviewer",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "approved",
          "transition_to": "commit_and_finish"
        },
        {
          "name": "changes_requested",
          "transition_to": "execute"
        },
        {
          "name": "failure",
          "transition_to": "close_reviewer_abort"
        },
        {
          "name": "needs_approval",
          "transition_to": "execute"
        },
        {
          "name": "needs_review",
          "transition_to": "execute"
        }
      ]
    },
    {
      "name": "execute",
      "agent": "executor",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_reviewer_abort"
        },
        {
          "name": "needs_approval",
          "transition_to": "verify"
        },
        {
          "name": "needs_review",
          "transition_to": "verify"
        }
      ]
    },
    {
      "name": "verify",
      "adapter": "shell",
      "timeout": "2m0s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "fix_verify"
        },
        {
          "name": "success",
          "transition_to": "review"
        }
      ]
    },
    {
      "name": "fix_verify",
      "agent": "executor",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_reviewer_abort"
        },
        {
          "name": "needs_approval",
          "transition_to": "verify"
        },
        {
          "name": "needs_review",
          "transition_to": "verify"
        }
      ]
    },
    {
      "name": "review",
      "agent": "reviewer",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "approved",
          "transition_to": "commit_and_finish"
        },
        {
          "name": "changes_requested",
          "transition_to": "execute"
        },
        {
          "name": "failure",
          "transition_to": "close_reviewer_abort"
        },
        {
          "name": "needs_approval",
          "transition_to": "execute"
        },
        {
          "name": "needs_review",
          "transition_to": "execute"
        }
      ]
    },
    {
      "name": "commit_and_finish",
      "agent": "executor",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_reviewer_abort"
        },
        {
          "name": "success",
          "transition_to": "close_reviewer_done"
        }
      ]
    },
    {
      "name": "close_reviewer_done",
      "agent": "reviewer",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_executor_done"
        },
        {
          "name": "success",
          "transition_to": "close_executor_done"
        }
      ]
    },
    {
      "name": "close_executor_done",
      "agent": "executor",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "done"
        },
        {
          "name": "success",
          "transition_to": "done"
        }
      ]
    },
    {
      "name": "close_reviewer_abort",
      "agent": "reviewer",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_executor_abort"
        },
        {
          "name": "success",
          "transition_to": "close_executor_abort"
        }
      ]
    },
    {
      "name": "close_executor_abort",
      "agent": "executor",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "failed"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "done",
      "terminal": true,
      "success": true
    },
    {
      "name": "failed",
      "terminal": true,
      "success": false
    }
  ],
  "step_order": [
    "load_executor_agent_file",
    "load_reviewer_agent_file",
    "open_executor",
    "open_reviewer",
    "execute_init",
    "review_init",
    "execute",
    "verify",
    "fix_verify",
    "review",
    "commit_and_finish",
    "close_reviewer_done",
    "close_executor_done",
    "close_reviewer_abort",
    "close_executor_abort"
  ],
  "plugins_required": [
    "copilot",
    "shell"
  ],
  "metadata": {
    "schema_version": 1
  }
}

digraph "agent_fix_test" {
  rankdir=LR;

  "test" [shape=box];
  "fix" [shape=box];
  "awaiting_human" [shape=doublecircle];
  "failed" [shape=doublecircle];
  "verified" [shape=doublecircle];

  "__start__" [shape=point,width=0.12,label=""];
  "__start__" -> "test" [label="initial"];
  "test" -> "fix" [label="failure"];
  "test" -> "verified" [label="success"];
  "fix" -> "failed" [label="failure"];
  "fix" -> "awaiting_human" [label="needs_review"];
  "fix" -> "test" [label="success"];
}

{
  "name": "demo_tour",
  "initial_state": "boot",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 40,
    "MaxStepRetries": 0
  },
  "agents": [],
  "steps": [
    {
      "name": "boot",
      "adapter": "shell",
      "timeout": "30s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "aborted"
        },
        {
          "name": "success",
          "transition_to": "discover"
        }
      ]
    },
    {
      "name": "discover",
      "adapter": "shell",
      "timeout": "30s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "aborted"
        },
        {
          "name": "success",
          "transition_to": "work"
        }
      ]
    },
    {
      "name": "work",
      "adapter": "shell",
      "timeout": "30s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "aborted"
        },
        {
          "name": "success",
          "transition_to": "loop_check"
        }
      ]
    },
    {
      "name": "loop_check",
      "adapter": "shell",
      "timeout": "10s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "verify"
        },
        {
          "name": "success",
          "transition_to": "work"
        }
      ]
    },
    {
      "name": "verify",
      "adapter": "shell",
      "timeout": "10s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "verify"
        },
        {
          "name": "success",
          "transition_to": "celebrate"
        }
      ]
    },
    {
      "name": "celebrate",
      "adapter": "shell",
      "timeout": "10s",
      "input_keys": [
        "command"
      ],
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "aborted"
        },
        {
          "name": "success",
          "transition_to": "done"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "aborted",
      "terminal": true,
      "success": false
    },
    {
      "name": "done",
      "terminal": true,
      "success": true
    }
  ],
  "step_order": [
    "boot",
    "discover",
    "work",
    "loop_check",
    "verify",
    "celebrate"
  ],
  "plugins_required": [
    "shell"
  ],
  "metadata": {
    "schema_version": 1
  }
}

{
  "name": "agent_hello",
  "initial_state": "open_assistant",
  "target_state": "done",
  "policy": {
    "MaxTotalSteps": 100,
    "MaxStepRetries": 0
  },
  "agents": [
    {
      "name": "assistant",
      "adapter": "copilot",
      "on_crash": "fail",
      "config_keys": [
        "max_turns"
      ]
    }
  ],
  "steps": [
    {
      "name": "open_assistant",
      "agent": "assistant",
      "lifecycle": "open",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "ask"
        }
      ]
    },
    {
      "name": "ask",
      "agent": "assistant",
      "input_keys": [
        "prompt"
      ],
      "allow_tools": [
        "shell:git*status*"
      ],
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "close_failed"
        },
        {
          "name": "needs_review",
          "transition_to": "close_needs_review"
        },
        {
          "name": "success",
          "transition_to": "close_done"
        }
      ]
    },
    {
      "name": "close_done",
      "agent": "assistant",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "done"
        }
      ]
    },
    {
      "name": "close_needs_review",
      "agent": "assistant",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "needs_review"
        }
      ]
    },
    {
      "name": "close_failed",
      "agent": "assistant",
      "lifecycle": "close",
      "input_keys": null,
      "allow_tools": null,
      "outcomes": [
        {
          "name": "failure",
          "transition_to": "failed"
        },
        {
          "name": "success",
          "transition_to": "failed"
        }
      ]
    }
  ],
  "states": [
    {
      "name": "done",
      "terminal": true,
      "success": true
    },
    {
      "name": "failed",
      "terminal": true,
      "success": false
    },
    {
      "name": "needs_review",
      "terminal": true,
      "success": false
    }
  ],
  "step_order": [
    "open_assistant",
    "ask",
    "close_done",
    "close_needs_review",
    "close_failed"
  ],
  "plugins_required": [
    "copilot"
  ],
  "metadata": {
    "schema_version": 1
  }
}

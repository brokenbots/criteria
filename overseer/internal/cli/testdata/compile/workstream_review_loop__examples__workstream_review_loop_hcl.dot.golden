digraph "workstream_review_loop" {
  rankdir=LR;

  "load_executor_agent_file" [shape=box];
  "load_reviewer_agent_file" [shape=box];
  "load_cleanup_agent_file" [shape=box];
  "open_executor" [shape=box];
  "open_reviewer" [shape=box];
  "open_cleanup" [shape=box];
  "execute" [shape=box];
  "review" [shape=box];
  "run_cleanup" [shape=box];
  "execute_fix_once" [shape=box];
  "run_cleanup_final" [shape=box];
  "close_cleanup_done" [shape=box];
  "close_reviewer_done" [shape=box];
  "close_executor_done" [shape=box];
  "close_cleanup_abort" [shape=box];
  "close_reviewer_abort" [shape=box];
  "close_executor_abort" [shape=box];
  "done" [shape=doublecircle];
  "failed" [shape=doublecircle];

  "__start__" [shape=point,width=0.12,label=""];
  "__start__" -> "load_executor_agent_file" [label="initial"];
  "load_executor_agent_file" -> "failed" [label="failure"];
  "load_executor_agent_file" -> "load_reviewer_agent_file" [label="success"];
  "load_reviewer_agent_file" -> "failed" [label="failure"];
  "load_reviewer_agent_file" -> "load_cleanup_agent_file" [label="success"];
  "load_cleanup_agent_file" -> "failed" [label="failure"];
  "load_cleanup_agent_file" -> "open_executor" [label="success"];
  "open_executor" -> "failed" [label="failure"];
  "open_executor" -> "open_reviewer" [label="success"];
  "open_reviewer" -> "close_executor_abort" [label="failure"];
  "open_reviewer" -> "open_cleanup" [label="success"];
  "open_cleanup" -> "close_reviewer_abort" [label="failure"];
  "open_cleanup" -> "execute" [label="success"];
  "execute" -> "close_cleanup_abort" [label="failure"];
  "execute" -> "review" [label="needs_approval"];
  "execute" -> "review" [label="needs_review"];
  "review" -> "run_cleanup" [label="approved"];
  "review" -> "execute" [label="changes_requested"];
  "review" -> "close_cleanup_abort" [label="failure"];
  "review" -> "execute" [label="needs_approval"];
  "review" -> "execute" [label="needs_review"];
  "run_cleanup" -> "close_cleanup_abort" [label="failure"];
  "run_cleanup" -> "execute_fix_once" [label="needs_fix"];
  "run_cleanup" -> "close_cleanup_done" [label="success"];
  "execute_fix_once" -> "close_cleanup_abort" [label="failure"];
  "execute_fix_once" -> "run_cleanup_final" [label="fixed"];
  "run_cleanup_final" -> "close_cleanup_abort" [label="failure"];
  "run_cleanup_final" -> "close_cleanup_done" [label="success"];
  "close_cleanup_done" -> "close_reviewer_done" [label="failure"];
  "close_cleanup_done" -> "close_reviewer_done" [label="success"];
  "close_reviewer_done" -> "close_executor_done" [label="failure"];
  "close_reviewer_done" -> "close_executor_done" [label="success"];
  "close_executor_done" -> "done" [label="failure"];
  "close_executor_done" -> "done" [label="success"];
  "close_cleanup_abort" -> "close_reviewer_abort" [label="failure"];
  "close_cleanup_abort" -> "close_reviewer_abort" [label="success"];
  "close_reviewer_abort" -> "close_executor_abort" [label="failure"];
  "close_reviewer_abort" -> "close_executor_abort" [label="success"];
  "close_executor_abort" -> "failed" [label="failure"];
  "close_executor_abort" -> "failed" [label="success"];
}

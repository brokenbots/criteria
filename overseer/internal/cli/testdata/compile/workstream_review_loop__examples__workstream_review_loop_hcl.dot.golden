digraph "workstream_review_loop" {
  rankdir=LR;

  "load_executor_agent_file" [shape=box];
  "load_reviewer_agent_file" [shape=box];
  "open_executor" [shape=box];
  "open_reviewer" [shape=box];
  "execute_init" [shape=box];
  "review_init" [shape=box];
  "execute" [shape=box];
  "verify" [shape=box];
  "fix_verify" [shape=box];
  "review" [shape=box];
  "commit_and_finish" [shape=box];
  "close_reviewer_done" [shape=box];
  "close_executor_done" [shape=box];
  "close_reviewer_abort" [shape=box];
  "close_executor_abort" [shape=box];
  "done" [shape=doublecircle];
  "failed" [shape=doublecircle];

  "__start__" [shape=point,width=0.12,label=""];
  "__start__" -> "load_executor_agent_file" [label="initial"];
  "load_executor_agent_file" -> "failed" [label="failure"];
  "load_executor_agent_file" -> "load_reviewer_agent_file" [label="success"];
  "load_reviewer_agent_file" -> "failed" [label="failure"];
  "load_reviewer_agent_file" -> "open_executor" [label="success"];
  "open_executor" -> "failed" [label="failure"];
  "open_executor" -> "open_reviewer" [label="success"];
  "open_reviewer" -> "close_executor_abort" [label="failure"];
  "open_reviewer" -> "execute_init" [label="success"];
  "execute_init" -> "close_reviewer_abort" [label="failure"];
  "execute_init" -> "review_init" [label="needs_approval"];
  "execute_init" -> "review_init" [label="needs_review"];
  "review_init" -> "commit_and_finish" [label="approved"];
  "review_init" -> "execute" [label="changes_requested"];
  "review_init" -> "close_reviewer_abort" [label="failure"];
  "review_init" -> "execute" [label="needs_approval"];
  "review_init" -> "execute" [label="needs_review"];
  "execute" -> "close_reviewer_abort" [label="failure"];
  "execute" -> "verify" [label="needs_approval"];
  "execute" -> "verify" [label="needs_review"];
  "verify" -> "fix_verify" [label="failure"];
  "verify" -> "review" [label="success"];
  "fix_verify" -> "close_reviewer_abort" [label="failure"];
  "fix_verify" -> "verify" [label="needs_approval"];
  "fix_verify" -> "verify" [label="needs_review"];
  "review" -> "commit_and_finish" [label="approved"];
  "review" -> "execute" [label="changes_requested"];
  "review" -> "close_reviewer_abort" [label="failure"];
  "review" -> "execute" [label="needs_approval"];
  "review" -> "execute" [label="needs_review"];
  "commit_and_finish" -> "close_reviewer_abort" [label="failure"];
  "commit_and_finish" -> "close_reviewer_done" [label="success"];
  "close_reviewer_done" -> "close_executor_done" [label="failure"];
  "close_reviewer_done" -> "close_executor_done" [label="success"];
  "close_executor_done" -> "done" [label="failure"];
  "close_executor_done" -> "done" [label="success"];
  "close_reviewer_abort" -> "close_executor_abort" [label="failure"];
  "close_reviewer_abort" -> "close_executor_abort" [label="success"];
  "close_executor_abort" -> "failed" [label="failure"];
  "close_executor_abort" -> "failed" [label="success"];
}

workflow: branch_basic  (version 0.1)
initial_state: build   target_state: done
policy: max_total_steps=100  max_step_retries=0

variables:
  (none)

agents:
  (none)

steps (declaration order):
  build   adapter=noop
    input keys: (none)
    allow_tools: (none)
    outcomes: success -> decide

states:
  deploy    terminal=true   success=true
  deploy_staging    terminal=true   success=true
  done    terminal=true   success=true
  skip_deploy    terminal=true   success=true

plugins required:
  noop   (search: $OVERLORD_PLUGINS, ~/.overlord/plugins)

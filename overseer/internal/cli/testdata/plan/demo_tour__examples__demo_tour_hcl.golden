workflow: demo_tour  (version 0.1)
initial_state: boot   target_state: done
policy: max_total_steps=40  max_step_retries=0

variables:
  (none)

agents:
  (none)

steps (declaration order):
  boot   adapter=shell   timeout=30s
    input keys: command
    allow_tools: (none)
    outcomes: success -> discover, failure -> aborted
  discover   adapter=shell   timeout=30s
    input keys: command
    allow_tools: (none)
    outcomes: success -> work, failure -> aborted
  work   adapter=shell   timeout=30s
    input keys: command
    allow_tools: (none)
    outcomes: success -> loop_check, failure -> aborted
  loop_check   adapter=shell   timeout=10s
    input keys: command
    allow_tools: (none)
    outcomes: success -> work, failure -> verify
  verify   adapter=shell   timeout=10s
    input keys: command
    allow_tools: (none)
    outcomes: success -> celebrate, failure -> verify
  celebrate   adapter=shell   timeout=10s
    input keys: command
    allow_tools: (none)
    outcomes: success -> done, failure -> aborted

states:
  aborted    terminal=true   success=false
  done    terminal=true   success=true

plugins required:
  shell   (search: $OVERLORD_PLUGINS, ~/.overlord/plugins)
